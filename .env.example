# ─── Base de données ──────────────────────────────────────
# PostgreSQL (production)
DATABASE_URL=postgresql://user:password@localhost:5432/archivision

# SQLite (développement)
# DATABASE_URL=file:./dev.db

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-very-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-very-long-random-string

# ─── IA (OpenRouter) ─────────────────────────────────────
# Créez un compte gratuit sur https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# Optionnel: OpenAI direct 
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ─── Serveur ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Client ──────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
